# ============================================================
# DevTools 环境变量配置示例
# 复制此文件为 .env 并填写真实值：cp .env.example .env
# .env 已加入 .gitignore，不会被提交到版本库
# ============================================================

# ---- 基础配置 ----
HOST_PORT=8082
DEEPSEEK_API_KEY=

# ---- AutoDev 配置 ----
# AutoDev 工具访问密码（必填，否则工具无法使用）
AUTODEV_ADMIN_PASSWORD=your_password_here

# ---- Claude API 配置（AutoDev 使用）----
# API 端点
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# API 认证 Token（必填）
ANTHROPIC_AUTH_TOKEN=sk-cp-your_token_here
# 使用的模型
ANTHROPIC_MODEL=MiniMax-M2.5
# 请求超时（毫秒）
API_TIMEOUT_MS=3000000
# 禁用非必要流量
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
